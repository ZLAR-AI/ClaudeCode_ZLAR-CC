# ZLAR Gateway Configuration
# Copy this file to .env and fill in your values.

# Telegram Bot Token — create one via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API Secret — used for HMAC authentication between gateway and mac-api
# Generate a random string: openssl rand -hex 32
ZLAR_API_SECRET=your_random_secret_here

# Port configuration (defaults shown)
# GATEWAY_PORT=3000
# MAC_API_PORT=4000
