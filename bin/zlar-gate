#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# ZLAR Gate — Claude Code Hook Script
#
# THE gate. Runs synchronously on every Claude Code PreToolUse hook invocation.
# Reads tool call from stdin, classifies, evaluates policy, asks Telegram if
# needed, writes audit trail, returns allow/deny on stdout.
#
# No daemon. No server. No database. The process IS the pending state.
#
# Ported from ZLAR-OC gate + current ZLAR classifier + hooks.ts.
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

# ERR trap — if anything fails unexpectedly, deny + log line number
trap 'echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] ERR at line ${LINENO} — denying" >> "${LOG_FILE:-/dev/null}" 2>/dev/null; respond_deny "Gate internal error at line ${LINENO}"; exit 0' ERR

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "${SCRIPT_DIR}")"

# ─── Configuration ──────────────────────────────────────────────────────────

GATE_CONFIG="${PROJECT_DIR}/etc/gate.json"
POLICY_FILE="${PROJECT_DIR}/etc/policies/active.policy.json"
POLICY_PUBKEY="${PROJECT_DIR}/etc/keys/policy-signing.pub"
AUDIT_FILE="${PROJECT_DIR}/var/log/audit.jsonl"
AVAILABILITY_STATE="${PROJECT_DIR}/var/log/availability.state"
AWAY_QUEUE="${PROJECT_DIR}/var/log/away-queue.jsonl"
LOCKDOWN_FILE="${PROJECT_DIR}/var/log/watchdog.lock"
SESSION_DIR="${PROJECT_DIR}/var/log/sessions"
LOG_FILE="${PROJECT_DIR}/var/log/gate.log"
TEMP_DIR="${PROJECT_DIR}/var/tmp"
mkdir -p "${TEMP_DIR}" && chmod 700 "${TEMP_DIR}" 2>/dev/null || true
trap 'rm -f "${TEMP_DIR}"/zlar-gate-$$.* 2>/dev/null || true' EXIT

# Load overrides from gate.json if present
if [ -f "${GATE_CONFIG}" ] && command -v jq &>/dev/null; then
    _cfg() { jq -r "$1 // empty" "${GATE_CONFIG}" 2>/dev/null; }
    TELEGRAM_CHAT_ID=$(_cfg '.telegram.chat_id')
    TELEGRAM_TIMEOUT_S=$(_cfg '.telegram.timeout_s')
    AWAY_THRESHOLD=$(_cfg '.availability.away_auto_allow_threshold')
    SESSION_WRITE_LIMIT=$(_cfg '.session_write_limit')
fi

# Env var overrides
TELEGRAM_TOKEN="${ZLAR_TELEGRAM_TOKEN:-${TELEGRAM_BOT_TOKEN:-}}"
TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID:-}"
TELEGRAM_TIMEOUT_S="${TELEGRAM_TIMEOUT_S:-300}"
AWAY_THRESHOLD="${AWAY_THRESHOLD:-30}"
SESSION_WRITE_LIMIT="${SESSION_WRITE_LIMIT:-50}"

# H3: Rate limiting — read from gate.json (these were dead config before this fix)
TELEGRAM_FLOOD_GUARD_MS="${TELEGRAM_FLOOD_GUARD_MS:-1500}"
RATE_LIMIT_FILE="${PROJECT_DIR}/var/log/.telegram-rate"
if [ -f "${GATE_CONFIG}" ] && command -v jq &>/dev/null; then
    _flood=$(_cfg '.telegram.flood_guard_ms')
    [ -n "${_flood}" ] && TELEGRAM_FLOOD_GUARD_MS="${_flood}"
fi

# A2: Karma thresholds integration — if calibrated thresholds exist, use them
KARMA_THRESHOLDS="${PROJECT_DIR}/var/log/karma-thresholds.json"
if [ -f "${KARMA_THRESHOLDS}" ] && command -v jq &>/dev/null; then
    local_threshold=$(jq -r '.effective_thresholds.allow // empty' "${KARMA_THRESHOLDS}" 2>/dev/null)
    if [ -n "${local_threshold}" ]; then
        AWAY_THRESHOLD="${local_threshold}"
    fi
fi

# Ensure log directory exists
mkdir -p "$(dirname "${AUDIT_FILE}")"
# Rotate audit file at 10MB
if [ -f "${AUDIT_FILE}" ] && [ "$(wc -c < "${AUDIT_FILE}" 2>/dev/null || echo 0)" -gt 10485760 ]; then
    mv "${AUDIT_FILE}" "${AUDIT_FILE}.$(date +%Y%m%d%H%M%S)" 2>/dev/null || true
fi

# ═══════════════════════════════════════════════════════════════════════════════
# STARTUP — handled by wrapper (~/.claude/zlar-gate.sh).
# The gate runs inside a $() subshell (thin hook line 21), so notifications
# sent here would be killed when the subshell exits. All startup notification
# logic lives in the wrapper, which runs as the top-level process.
# ═══════════════════════════════════════════════════════════════════════════════

# Sequence counter (per invocation, starts at 0)
SEQ=0

# ─── Logging ────────────────────────────────────────────────────────────────

log() {
    local ts
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    echo "[${ts}] $*" >> "${LOG_FILE}" 2>/dev/null || true
}

# ─── Response Helpers ───────────────────────────────────────────────────────

respond_allow() {
    echo '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"allow"}}'
}

respond_deny() {
    local reason="${1:-Policy denied}"
    # T1-2: Use jq for safe JSON string escaping (handles \, newlines, tabs, etc.)
    local escaped
    escaped=$(echo "${reason}" | head -c 200 | jq -Rrs '.' | sed 's/^"//;s/"$//')
    printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"%s"}}\n' "${escaped}"
}

# ─── UUID Generation ────────────────────────────────────────────────────────

gen_id() {
    local hex_ts
    hex_ts=$(printf '%x' "$(date +%s)")
    # T1-3: 128-bit random nonce (was 48-bit, predictable)
    local rand
    rand=$(openssl rand -hex 16 2>/dev/null || head -c 32 /dev/urandom | xxd -p)
    echo "${hex_ts}-${rand}"
}

# ─── Audit Event Emission ──────────────────────────────────────────────────

emit_event() {
    local domain="$1" action="$2" outcome="$3" detail="$4" rule="$5" severity="$6" risk_score="${7:-0}" authorizer="${8:-system}"
    local id ts
    id=$(gen_id)
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    SEQ=$((SEQ + 1))

    # A1: Hash chain — compute prev_hash from last audit line
    local prev_hash="genesis"
    if [ -f "${AUDIT_FILE}" ] && [ -s "${AUDIT_FILE}" ]; then
        prev_hash=$(tail -1 "${AUDIT_FILE}" 2>/dev/null | shasum -a 256 | awk '{print $1}')
    fi

    local event
    event=$(jq -n -c \
        --arg id "${id}" \
        --arg ts "${ts}" \
        --argjson seq "${SEQ}" \
        --arg source "gate" \
        --arg host "$(hostname -s)" \
        --arg user "$(whoami)" \
        --arg agent_id "claude-code" \
        --arg session_id "${SESSION_ID:-unknown}" \
        --arg domain "${domain}" \
        --arg action "${action}" \
        --arg outcome "${outcome}" \
        --argjson risk_score "${risk_score}" \
        --argjson detail "${detail}" \
        --arg rule "${rule}" \
        --arg policy_version "${POLICY_VERSION:-unknown}" \
        --arg severity "${severity}" \
        --arg prev_hash "${prev_hash}" \
        --arg authorizer "${authorizer}" \
        '{id:$id,ts:$ts,seq:$seq,source:$source,host:$host,user:$user,
          agent_id:$agent_id,session_id:$session_id,domain:$domain,
          action:$action,outcome:$outcome,risk_score:$risk_score,
          detail:$detail,rule:$rule,policy_version:$policy_version,
          severity:$severity,prev_hash:$prev_hash,authorizer:$authorizer}')

    if ! echo "${event}" >> "${AUDIT_FILE}" 2>/dev/null; then
        log "CRITICAL: Failed to write audit event — audit trail may be incomplete"
    fi
}

# ─── Tool Translation ──────────────────────────────────────────────────────

DOMAIN=""
DETAIL="{}"
TOOL_DISPLAY=""
TELEGRAM_DENIED_BY=""

translate_tool() {
    local tool_name="$1"
    local tool_input="$2"

    case "${tool_name}" in
        Bash)
            DOMAIN="bash"
            DETAIL=$(echo "${tool_input}" | jq -c '{command: (.command // ""), cwd: (.cwd // "")}' 2>/dev/null || echo '{"command":""}')
            # S2: Newline injection fix — collapse newlines before classification
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.command // ""' 2>/dev/null | tr '\n\r' '  ' | head -c 200)
            ;;
        Write)
            DOMAIN="write"
            local content_hash
            content_hash=$(echo "${tool_input}" | jq -r '.content // ""' 2>/dev/null | shasum -a 256 | awk '{print $1}')
            DETAIL=$(echo "${tool_input}" | jq -c --arg hash "${content_hash}" '{path: (.file_path // ""), content_length: ((.content // "") | length), content_sha256: $hash}' 2>/dev/null || echo '{"path":""}')
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.file_path // ""' 2>/dev/null)
            ;;
        Edit)
            DOMAIN="edit"
            DETAIL=$(echo "${tool_input}" | jq -c '{path: (.file_path // ""), old_string: ((.old_string // "")[0:80]), new_string: ((.new_string // "")[0:80])}' 2>/dev/null || echo '{"path":""}')
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.file_path // ""' 2>/dev/null)
            ;;
        Read)
            DOMAIN="read"
            DETAIL=$(echo "${tool_input}" | jq -c '{path: (.file_path // "")}' 2>/dev/null || echo '{"path":""}')
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.file_path // ""' 2>/dev/null)
            ;;
        Glob)
            DOMAIN="glob"
            DETAIL=$(echo "${tool_input}" | jq -c '{pattern: (.pattern // ""), path: (.path // "")}' 2>/dev/null || echo '{"pattern":""}')
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.pattern // ""' 2>/dev/null)
            ;;
        Grep)
            DOMAIN="grep"
            DETAIL=$(echo "${tool_input}" | jq -c '{pattern: (.pattern // ""), path: (.path // "")}' 2>/dev/null || echo '{"pattern":""}')
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.pattern // ""' 2>/dev/null)
            ;;
        NotebookEdit)
            DOMAIN="notebook"
            DETAIL=$(echo "${tool_input}" | jq -c '{path: (.notebook_path // "")}' 2>/dev/null || echo '{"path":""}')
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.notebook_path // ""' 2>/dev/null)
            ;;
        Task|Agent)
            DOMAIN="agent"
            DETAIL=$(echo "${tool_input}" | jq -c '{prompt: ((.prompt // .description // "subagent")[0:200])}' 2>/dev/null || echo '{"prompt":"subagent"}')
            TOOL_DISPLAY="Sub-agent"
            ;;
        WebFetch)
            DOMAIN="webfetch"
            DETAIL=$(echo "${tool_input}" | jq -c '{url: (.url // "")}' 2>/dev/null || echo '{"url":""}')
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.url // ""' 2>/dev/null)
            ;;
        WebSearch)
            DOMAIN="websearch"
            DETAIL=$(echo "${tool_input}" | jq -c '{query: (.query // "")}' 2>/dev/null || echo '{"query":""}')
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.query // ""' 2>/dev/null)
            ;;
        TodoWrite)
            DOMAIN="internal"
            DETAIL=$(echo "${tool_input}" | jq -c '{todos: ((.todos // []) | length)}' 2>/dev/null || echo '{"todos":0}')
            TOOL_DISPLAY="TodoWrite ($(echo "${tool_input}" | jq -r '(.todos // []) | length' 2>/dev/null) items)"
            ;;
        TaskOutput)
            DOMAIN="internal"
            DETAIL=$(echo "${tool_input}" | jq -c '{task_id: (.task_id // "")}' 2>/dev/null || echo '{"task_id":""}')
            TOOL_DISPLAY=$(echo "${tool_input}" | jq -r '.task_id // "task"' 2>/dev/null)
            ;;
        TaskStop)
            DOMAIN="internal"
            DETAIL=$(echo "${tool_input}" | jq -c '{task_id: (.task_id // "")}' 2>/dev/null || echo '{"task_id":""}')
            TOOL_DISPLAY="Stop: $(echo "${tool_input}" | jq -r '.task_id // "task"' 2>/dev/null)"
            ;;
        Skill)
            DOMAIN="internal"
            DETAIL=$(echo "${tool_input}" | jq -c '{skill: (.skill // ""), args: (.args // "")}' 2>/dev/null || echo '{"skill":""}')
            TOOL_DISPLAY="Skill: $(echo "${tool_input}" | jq -r '.skill // "unknown"' 2>/dev/null)"
            ;;
        EnterPlanMode|ExitPlanMode)
            DOMAIN="internal"
            DETAIL=$(jq -n -c --arg mode "${tool_name}" '{mode: $mode}')
            TOOL_DISPLAY="${tool_name}"
            ;;
        AskUserQuestion)
            DOMAIN="internal"
            DETAIL=$(echo "${tool_input}" | jq -c '{questions: ((.questions // []) | length)}' 2>/dev/null || echo '{"questions":0}')
            TOOL_DISPLAY="AskUserQuestion"
            ;;
        EnterWorktree|ExitWorktree)
            DOMAIN="internal"
            DETAIL=$(echo "${tool_input}" | jq -c '.' 2>/dev/null || echo '{}')
            TOOL_DISPLAY="${tool_name}"
            ;;
        mcp__*)
            DOMAIN="mcp"
            # Extract server and tool from mcp__<server>__<tool> format
            local mcp_rest="${tool_name#mcp__}"
            local mcp_server="${mcp_rest%%__*}"
            local mcp_tool="${mcp_rest#*__}"
            DETAIL=$(jq -n -c --arg server "${mcp_server}" --arg tool "${mcp_tool}" --arg full "${tool_name}"                 '{server: $server, tool: $tool, full_name: $full}')
            TOOL_DISPLAY="MCP:${mcp_server}/${mcp_tool}"
            ;;

        *)
            DOMAIN="unknown"
            # T2-10: Safe JSON construction for unknown tools (was string interpolation)
            DETAIL=$(jq -n -c --arg t "${tool_name}" '{tool: $t}')
            TOOL_DISPLAY="${tool_name}"
            ;;
    esac
}

# ─── Policy Loader ──────────────────────────────────────────────────────────

POLICY_VERSION=""
POLICY_DEFAULT_ACTION="deny"
POLICY_RULES_JSON=""
POLICY_LOADED="false"

load_policy() {
    if [ ! -f "${POLICY_FILE}" ]; then
        log "FATAL: Policy file not found: ${POLICY_FILE}"
        return 1
    fi

    # A4: Policy verification cache — skip Ed25519 if content hash unchanged
    # TOCTOU fix: uses SHA-256 of file content instead of mtime+size
    local cache_file="${PROJECT_DIR}/var/log/.policy-cache"
    local policy_hash
    policy_hash=$(shasum -a 256 "${POLICY_FILE}" 2>/dev/null | awk '{print $1}')
    if [ -n "${policy_hash}" ] && [ -f "${cache_file}" ]; then
        local cached_hash
        cached_hash=$(cat "${cache_file}" 2>/dev/null | tr -d '[:space:]')
        if [ "${policy_hash}" = "${cached_hash}" ]; then
            # Cache hit — content unchanged, skip verification, just load rules
            POLICY_VERSION=$(jq -r '.version // "unknown"' "${POLICY_FILE}" 2>/dev/null)
            POLICY_DEFAULT_ACTION=$(jq -r '.default_action // "deny"' "${POLICY_FILE}" 2>/dev/null)
            POLICY_RULES_JSON=$(jq -c '.rules' "${POLICY_FILE}" 2>/dev/null)
    # shellcheck disable=SC2034
            POLICY_LOADED="true"
            log "Policy loaded (cached, hash verified): v${POLICY_VERSION}"
            return 0
        fi
    fi

    # Fail-closed: public key MUST exist for signature verification
    if [ ! -f "${POLICY_PUBKEY}" ]; then
        log "FATAL: Policy public key not found — cannot verify signature"
        return 1
    fi

    # Verify signature
    {
        local sig_value
        sig_value=$(jq -r '.signature.value // ""' "${POLICY_FILE}" 2>/dev/null)
        if [ -z "${sig_value}" ] || [ "${sig_value}" = "" ]; then
            log "FATAL: Policy is unsigned"
            return 1
        fi

        # Create canonical form
        local canon_file hash_file sig_file
        canon_file=$(mktemp /tmp/zlar-gate-canon.XXXXXX)
        hash_file=$(mktemp /tmp/zlar-gate-hash.XXXXXX)
        sig_file=$(mktemp /tmp/zlar-gate-sig.XXXXXX)

        jq '.signature.value = ""' "${POLICY_FILE}" > "${canon_file}" 2>/dev/null
        shasum -a 256 "${canon_file}" | awk '{print $1}' | tr -d '\n' > "${hash_file}"
        echo "${sig_value}" | base64 -d > "${sig_file}" 2>/dev/null

        if ! openssl pkeyutl -verify \
            -pubin -inkey "${POLICY_PUBKEY}" -rawin \
            -sigfile "${sig_file}" \
            -in "${hash_file}" &>/dev/null; then
            rm -f "${canon_file}" "${hash_file}" "${sig_file}"
            log "FATAL: Policy signature INVALID"
            return 1
        fi
        rm -f "${canon_file}" "${hash_file}" "${sig_file}"
    }

    # Parse policy
    POLICY_VERSION=$(jq -r '.version // "unknown"' "${POLICY_FILE}" 2>/dev/null)
    POLICY_DEFAULT_ACTION=$(jq -r '.default_action // "deny"' "${POLICY_FILE}" 2>/dev/null)
    POLICY_RULES_JSON=$(jq -c '.rules' "${POLICY_FILE}" 2>/dev/null)
    # shellcheck disable=SC2034
    POLICY_LOADED="true"

    # A4: Update verification cache with content hash
    if [ -n "${policy_hash}" ]; then
        echo "${policy_hash}" > "${cache_file}" 2>/dev/null || true
    fi

    log "Policy loaded: v${POLICY_VERSION}, default=${POLICY_DEFAULT_ACTION}"
}

# ─── Detail Matcher ─────────────────────────────────────────────────────────

match_detail_field() {
    local actual_value="$1"
    local matcher_json="$2"

    # Check each matcher type
    # shellcheck disable=SC2034
    local op val

    # regex
    val=$(echo "${matcher_json}" | jq -r '.regex // empty' 2>/dev/null)
    if [ -n "${val}" ]; then
        if echo "${actual_value}" | grep -qE "${val}" 2>/dev/null; then
            return 0
        fi
        return 1
    fi

    # contains
    val=$(echo "${matcher_json}" | jq -r '.contains // empty' 2>/dev/null)
    if [ -n "${val}" ]; then
        if echo "${actual_value}" | grep -qF "${val}" 2>/dev/null; then
            return 0
        fi
        return 1
    fi

    # prefix
    val=$(echo "${matcher_json}" | jq -r '.prefix // empty' 2>/dev/null)
    if [ -n "${val}" ]; then
        if [[ "${actual_value}" == "${val}"* ]]; then
            return 0
        fi
        return 1
    fi

    # eq
    val=$(echo "${matcher_json}" | jq -r '.eq // empty' 2>/dev/null)
    if [ -n "${val}" ]; then
        if [ "${actual_value}" = "${val}" ]; then
            return 0
        fi
        return 1
    fi

    # not_regex
    val=$(echo "${matcher_json}" | jq -r '.not_regex // empty' 2>/dev/null)
    if [ -n "${val}" ]; then
        if echo "${actual_value}" | grep -qE "${val}" 2>/dev/null; then
            return 1
        fi
        return 0
    fi

    return 1
}

# ─── Policy Evaluator ──────────────────────────────────────────────────────

MATCHED_RULE=""
MATCHED_ACTION=""
MATCHED_SEVERITY=""
MATCHED_RISK_SCORE=0
MATCHED_AUDIT="true"

evaluate_policy() {
    local domain="$1"
    local detail="$2"

    MATCHED_RULE=""
    MATCHED_ACTION=""
    MATCHED_SEVERITY="info"
    MATCHED_RISK_SCORE=0
    MATCHED_AUDIT="true"

    local rule_count
    rule_count=$(echo "${POLICY_RULES_JSON}" | jq 'length' 2>/dev/null || echo 0)

    local i=0
    while [ "${i}" -lt "${rule_count}" ]; do
        local rule
        rule=$(echo "${POLICY_RULES_JSON}" | jq -c ".[${i}]" 2>/dev/null)

        # Skip disabled rules
        local enabled
        enabled=$(echo "${rule}" | jq -r '.enabled // true' 2>/dev/null)
        if [ "${enabled}" = "false" ]; then
            i=$((i + 1))
            continue
        fi

        # Check domain match
        local rule_domain
        rule_domain=$(echo "${rule}" | jq -r '.domain // ""' 2>/dev/null)
        if [ -n "${rule_domain}" ] && [ "${rule_domain}" != "${domain}" ]; then
            i=$((i + 1))
            continue
        fi

        # Check match conditions
        local match_json
        match_json=$(echo "${rule}" | jq -c '.match // {}' 2>/dev/null)

        # Domain-only match (catch-all for this domain)
        local match_domain_only
        match_domain_only=$(echo "${match_json}" | jq -r '.domain // empty' 2>/dev/null)
        if [ -n "${match_domain_only}" ] && [ "${match_domain_only}" = "${domain}" ]; then
            # Check if there are also detail matchers
            local has_detail
            has_detail=$(echo "${match_json}" | jq 'has("detail")' 2>/dev/null)
            if [ "${has_detail}" != "true" ]; then
                # Pure domain match — this is a catch-all
                _set_matched "${rule}"
                return 0
            fi
        fi

        # Detail matchers
        local has_detail
        has_detail=$(echo "${match_json}" | jq 'has("detail")' 2>/dev/null)
        if [ "${has_detail}" = "true" ]; then
            local detail_match_json
            detail_match_json=$(echo "${match_json}" | jq -c '.detail' 2>/dev/null)
            local all_matched="true"

            # Iterate detail fields
            local fields
            fields=$(echo "${detail_match_json}" | jq -r 'keys[]' 2>/dev/null)
            for field in ${fields}; do
                local actual_value matcher_json
                actual_value=$(echo "${detail}" | jq -r ".${field} // \"\"" 2>/dev/null)
                matcher_json=$(echo "${detail_match_json}" | jq -c ".${field}" 2>/dev/null)

                if ! match_detail_field "${actual_value}" "${matcher_json}"; then
                    all_matched="false"
                    break
                fi
            done

            if [ "${all_matched}" = "true" ]; then
                # Check compound_guard if present
                local has_guard
                has_guard=$(echo "${match_json}" | jq 'has("compound_guard")' 2>/dev/null)
                if [ "${has_guard}" = "true" ]; then
                    local guard_json
                    guard_json=$(echo "${match_json}" | jq -c '.compound_guard' 2>/dev/null)
                    local guard_fields
                    guard_fields=$(echo "${guard_json}" | jq -r 'keys[]' 2>/dev/null)
                    local guard_passed="true"
                    for gfield in ${guard_fields}; do
                        local gval gmatcher
                        gval=$(echo "${detail}" | jq -r ".${gfield} // \"\"" 2>/dev/null)
                        gmatcher=$(echo "${guard_json}" | jq -c ".${gfield}" 2>/dev/null)
                        if ! match_detail_field "${gval}" "${gmatcher}"; then
                            guard_passed="false"
                            break
                        fi
                    done
                    if [ "${guard_passed}" = "false" ]; then
                        i=$((i + 1))
                        continue
                    fi
                fi

                _set_matched "${rule}"
                return 0
            fi
        fi

        i=$((i + 1))
    done

    # No match — default action (still returns 0; caller checks MATCHED_RULE)
    MATCHED_ACTION="${POLICY_DEFAULT_ACTION}"
    MATCHED_RULE="default"
    MATCHED_SEVERITY="warn"
    return 0
}

_set_matched() {
    local rule="$1"
    MATCHED_RULE=$(echo "${rule}" | jq -r '.id // "unknown"' 2>/dev/null)
    MATCHED_ACTION=$(echo "${rule}" | jq -r '.action // "deny"' 2>/dev/null)
    MATCHED_SEVERITY=$(echo "${rule}" | jq -r '.severity // "info"' 2>/dev/null)
    MATCHED_AUDIT=$(echo "${rule}" | jq -r '.audit // true' 2>/dev/null)

    # Compute risk score from rule's risk_score field
    local has_score
    has_score=$(echo "${rule}" | jq 'has("risk_score")' 2>/dev/null)
    if [ "${has_score}" = "true" ]; then
        local irrev consq blast
        irrev=$(echo "${rule}" | jq -r '.risk_score.irreversibility // 0' 2>/dev/null)
        consq=$(echo "${rule}" | jq -r '.risk_score.consequence // 0' 2>/dev/null)
        blast=$(echo "${rule}" | jq -r '.risk_score.blast_radius // 0' 2>/dev/null)
        # Score = max of three axes
        MATCHED_RISK_SCORE="${irrev}"
        if [ "${consq}" -gt "${MATCHED_RISK_SCORE}" ]; then MATCHED_RISK_SCORE="${consq}"; fi
        if [ "${blast}" -gt "${MATCHED_RISK_SCORE}" ]; then MATCHED_RISK_SCORE="${blast}"; fi
    else
        MATCHED_RISK_SCORE=0
    fi
}

# ─── Availability Mode ──────────────────────────────────────────────────────

get_availability_mode() {
    if [ -f "${AVAILABILITY_STATE}" ]; then
        jq -r '.mode // "active"' "${AVAILABILITY_STATE}" 2>/dev/null || echo "active"
    else
        echo "active"
    fi
}

queue_for_review() {
    local detail="$1" rule="$2" risk_score="$3"
    local entry
    entry=$(jq -n -c \
        --arg id "$(gen_id)" \
        --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        --arg rule "${rule}" \
        --arg domain "${DOMAIN}" \
        --argjson detail "${detail}" \
        --argjson risk_score "${risk_score}" \
        '{id:$id,ts:$ts,rule:$rule,domain:$domain,detail:$detail,risk_score:$risk_score}')
    echo "${entry}" >> "${AWAY_QUEUE}" 2>/dev/null || true
}

# ─── Telegram Ask Channel ──────────────────────────────────────────────────

telegram_api() {
    local method="$1" body="$2"
    curl -s --connect-timeout 5 --max-time 10 \
        -X POST "https://api.telegram.org/bot${TELEGRAM_TOKEN}/${method}" \
        -H "Content-Type: application/json" \
        -d "${body}" 2>/dev/null
}

telegram_ask() {
    local action_id="$1" tool_name="$2" display="$3" rule="$4" risk_score="$5" severity="$6"

    if [ -z "${TELEGRAM_TOKEN}" ]; then
        log "No Telegram token — denying ask action"
        TELEGRAM_DENIED_BY="send_failure"
        return 2
    fi

    # H3: Rate limiting — deny if asks are coming too fast
    local now_ms
    now_ms=$(date +%s%N 2>/dev/null | cut -c1-13 || echo "$(($(date +%s) * 1000))")
    if [ -f "${RATE_LIMIT_FILE}" ]; then
        local last_ms
        last_ms=$(cat "${RATE_LIMIT_FILE}" 2>/dev/null | tr -d '[:space:]')
        last_ms=${last_ms:-0}
        local elapsed_ms=$((now_ms - last_ms))
        if [ "${elapsed_ms}" -lt "${TELEGRAM_FLOOD_GUARD_MS}" ]; then
            log "RATE LIMITED: ${elapsed_ms}ms since last ask (guard=${TELEGRAM_FLOOD_GUARD_MS}ms)"
            TELEGRAM_DENIED_BY="rate_limit"
            return 3
        fi
    fi
    echo "${now_ms}" > "${RATE_LIMIT_FILE}" 2>/dev/null || true

    # Format message
    local emoji="⚡"
    [ "${severity}" = "critical" ] && emoji="🔴"
    [ "${severity}" = "warn" ] && emoji="🟡"

    local text="${emoji} *ZLAR Gate*

*Tool:* \`${tool_name}\`
*Detail:* \`${display}\`
*Risk:* ${risk_score}/100
*Rule:* ${rule}"

    # Escape special chars for Telegram Markdown
    # shellcheck disable=SC2016
    text=$(echo "${text}" | sed 's/[_\[\]()~>#+=|{}.!-]/\\&/g' | sed 's/\\`/`/g' | sed 's/\\\*/*/g')

    local keyboard
    keyboard=$(jq -n -c \
        --arg aid "${action_id}" \
        '{inline_keyboard: [[
            {text: "✅ Approve", callback_data: ("approve:" + $aid)},
            {text: "❌ Deny", callback_data: ("deny:" + $aid)}
        ]]}')

    local send_body
    send_body=$(jq -n -c \
        --arg chat_id "${TELEGRAM_CHAT_ID}" \
        --arg text "${text}" \
        --argjson reply_markup "${keyboard}" \
        '{chat_id: $chat_id, text: $text, parse_mode: "MarkdownV2", reply_markup: $reply_markup}')

    local send_result
    send_result=$(telegram_api "sendMessage" "${send_body}")

    local msg_id
    msg_id=$(echo "${send_result}" | jq -r '.result.message_id // empty' 2>/dev/null)

    if [ -z "${msg_id}" ]; then
        log "Failed to send Telegram message: ${send_result}"
        TELEGRAM_DENIED_BY="send_failure"
        return 2
    fi

    log "Telegram ask sent: msg_id=${msg_id}, action_id=${action_id}"

    # Record send time for audit
    emit_event "${DOMAIN}" "ask_sent" "pending" "${DETAIL}" "${rule}" "${severity}" "${risk_score}"

    # Poll for response
    local deadline=$(($(date +%s) + TELEGRAM_TIMEOUT_S))
    local last_update_id=0

    while [ "$(date +%s)" -lt "${deadline}" ]; do
        local poll_body
        poll_body=$(jq -n -c \
            --argjson offset "$((last_update_id + 1))" \
            --argjson timeout 3 \
            '{offset: $offset, timeout: $timeout, allowed_updates: ["callback_query"]}')

        local updates
        updates=$(telegram_api "getUpdates" "${poll_body}")

        local count
        count=$(echo "${updates}" | jq '.result | length' 2>/dev/null || echo 0)

        local j=0
        while [ "${j}" -lt "${count}" ]; do
            local update
            update=$(echo "${updates}" | jq -c ".result[${j}]" 2>/dev/null)
            last_update_id=$(echo "${update}" | jq -r '.update_id' 2>/dev/null)

            local cb_data
            cb_data=$(echo "${update}" | jq -r '.callback_query.data // ""' 2>/dev/null)
            local cb_id
            cb_id=$(echo "${update}" | jq -r '.callback_query.id // ""' 2>/dev/null)

            # H2: Verify callback sender matches authorized chat_id
            local cb_from
            cb_from=$(echo "${update}" | jq -r '.callback_query.from.id // ""' 2>/dev/null)
            if [ "${cb_from}" != "${TELEGRAM_CHAT_ID}" ]; then
                log "UNAUTHORIZED callback from user ${cb_from} (expected ${TELEGRAM_CHAT_ID})"
                telegram_api "answerCallbackQuery" "$(jq -n -c --arg id "${cb_id}" '{callback_query_id: $id, text: "Unauthorized"}')" >/dev/null
                j=$((j + 1))
                continue
            fi

            if [ "${cb_data}" = "approve:${action_id}" ]; then
                # Answer callback
                telegram_api "answerCallbackQuery" "$(jq -n -c --arg id "${cb_id}" '{callback_query_id: $id, text: "Approved"}')" >/dev/null
                # Update message with structured receipt
                local approve_ts
                approve_ts=$(date +%H:%M:%S)
                local elapsed_s=$(( $(date +%s) - (deadline - TELEGRAM_TIMEOUT_S) ))
                local receipt_text="✅ *APPROVED*

*Tool:* \`${tool_name}\`
*Detail:* \`${display}\`
*Risk:* ${risk_score}/100
*Rule:* ${rule}
*Session:* \`${SESSION_ID}\`
*Decision:* Approved @ ${approve_ts}
*Latency:* ${elapsed_s}s"
                # shellcheck disable=SC2016
                receipt_text=$(echo "${receipt_text}" | sed 's/[_\[\]()~>#+=|{}.!-]/\\&/g' | sed 's/\\`/`/g' | sed 's/\\*/*/g')
                local edit_body
                edit_body=$(jq -n -c \
                    --arg chat_id "${TELEGRAM_CHAT_ID}" \
                    --argjson msg_id "${msg_id}" \
                    --arg text "${receipt_text}" \
                    '{chat_id: $chat_id, message_id: $msg_id, text: $text, parse_mode: "MarkdownV2"}')
                telegram_api "editMessageText" "${edit_body}" >/dev/null
                TELEGRAM_DENIED_BY=""
                log "Telegram: APPROVED by human (${elapsed_s}s)"
                return 0
            elif [ "${cb_data}" = "deny:${action_id}" ]; then
                telegram_api "answerCallbackQuery" "$(jq -n -c --arg id "${cb_id}" '{callback_query_id: $id, text: "Denied"}')" >/dev/null
                local deny_ts
                deny_ts=$(date +%H:%M:%S)
                local elapsed_s=$(( $(date +%s) - (deadline - TELEGRAM_TIMEOUT_S) ))
                local receipt_text="❌ *DENIED*

*Tool:* \`${tool_name}\`
*Detail:* \`${display}\`
*Risk:* ${risk_score}/100
*Rule:* ${rule}
*Session:* \`${SESSION_ID}\`
*Decision:* Denied @ ${deny_ts}
*Latency:* ${elapsed_s}s"
                # shellcheck disable=SC2016
                receipt_text=$(echo "${receipt_text}" | sed 's/[_\[\]()~>#+=|{}.!-]/\\&/g' | sed 's/\\`/`/g' | sed 's/\\*/*/g')
                local edit_body
                edit_body=$(jq -n -c \
                    --arg chat_id "${TELEGRAM_CHAT_ID}" \
                    --argjson msg_id "${msg_id}" \
                    --arg text "${receipt_text}" \
                    '{chat_id: $chat_id, message_id: $msg_id, text: $text, parse_mode: "MarkdownV2"}')
                telegram_api "editMessageText" "${edit_body}" >/dev/null
                TELEGRAM_DENIED_BY="human"
                log "Telegram: DENIED by human (${elapsed_s}s)"
                return 1  # exit code 1 = human denied
            fi

            j=$((j + 1))
        done
    done

    # Timeout
    log "Telegram: TIMED OUT after ${TELEGRAM_TIMEOUT_S}s"
    local receipt_text="⏰ *TIMED OUT*

*Tool:* \`${tool_name}\`
*Detail:* \`${display}\`
*Risk:* ${risk_score}/100
*Rule:* ${rule}
*Timeout:* ${TELEGRAM_TIMEOUT_S}s — action blocked"
    # shellcheck disable=SC2016
    receipt_text=$(echo "${receipt_text}" | sed 's/[_\[\]()~>#+=|{}.!-]/\\&/g' | sed 's/\\`/`/g' | sed 's/\\*/*/g')
    local timeout_body
    timeout_body=$(jq -n -c \
        --arg chat_id "${TELEGRAM_CHAT_ID}" \
        --argjson msg_id "${msg_id}" \
        --arg text "${receipt_text}" \
        '{chat_id: $chat_id, message_id: $msg_id, text: $text, parse_mode: "MarkdownV2"}')
    telegram_api "editMessageText" "${timeout_body}" >/dev/null
    TELEGRAM_DENIED_BY="timeout"
    return 4  # exit code 4 = timeout
}

# ─── Main Gate Logic ────────────────────────────────────────────────────────

main() {
    # Keepalive touch — update active flag for menu bar on every invocation
    # shellcheck disable=SC2005
    echo "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "${PROJECT_DIR}/var/log/.gate-active" 2>/dev/null

    # 1. Read hook input from stdin
    local input
    input=$(cat)

    if [ -z "${input}" ]; then
        log "Empty input — denying"
        respond_deny "Empty hook input"
        return
    fi

    # 2. Validate JSON
    if ! echo "${input}" | jq empty 2>/dev/null; then
        log "Malformed JSON input — denying"
        respond_deny "Malformed hook input"
        return
    fi

    # 3. Extract tool info
    local tool_name tool_input
    tool_name=$(echo "${input}" | jq -r '.tool_name // ""' 2>/dev/null)
    tool_input=$(echo "${input}" | jq -c '.tool_input // {}' 2>/dev/null)
    SESSION_ID=$(echo "${input}" | jq -r '.session_id // "unknown"' 2>/dev/null)
    # T1-1: Sanitize SESSION_ID — prevent path traversal in session counter file
    SESSION_ID=$(echo "${SESSION_ID}" | tr -cd 'a-zA-Z0-9_-' | head -c 64)

    if [ -z "${tool_name}" ]; then
        log "No tool_name in input — denying"
        respond_deny "No tool name"
        return
    fi

    # 4. Check watchdog lockdown
    if [ -f "${LOCKDOWN_FILE}" ]; then
        local lock_data
        lock_data=$(jq -r '.locked // false' "${LOCKDOWN_FILE}" 2>/dev/null)
        if [ "${lock_data}" = "true" ]; then
            local lock_reason
            lock_reason=$(jq -r '.reason // "Watchdog lockdown"' "${LOCKDOWN_FILE}" 2>/dev/null)
            log "LOCKDOWN: ${lock_reason}"
            translate_tool "${tool_name}" "${tool_input}"
            emit_event "${DOMAIN}" "${tool_name}" "deny" '{"reason":"'"${lock_reason}"'"}' "watchdog-lock" "critical" 100
            respond_deny "ZLAR lockdown: ${lock_reason}"
            return
        fi
    fi

    # 5. Translate tool to domain + detail
    translate_tool "${tool_name}" "${tool_input}"
    log "Tool: ${tool_name} → domain=${DOMAIN}, display=${TOOL_DISPLAY}"

    # 5a. Internal fast-path — no policy evaluation needed for conversation-internal tools
    if [ "${DOMAIN}" = "internal" ]; then
        emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "allow" "${DETAIL}" "internal-fast-path" "info" 0 "gate"
        respond_allow
        return
    fi

    # 4. Load and verify policy
    if ! load_policy; then
        log "Policy load failed — denying all"
        emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "deny" "${DETAIL}" "policy-error" "critical" 0
        respond_deny "ZLAR policy error. All actions blocked."
        return
    fi

    # 5. Evaluate against policy rules
    evaluate_policy "${DOMAIN}" "${DETAIL}"
    log "Rule: ${MATCHED_RULE}, action=${MATCHED_ACTION}, risk=${MATCHED_RISK_SCORE}, severity=${MATCHED_SEVERITY}"

    # M5: Session write counter — deny if session exceeds write limit
    if [ "${DOMAIN}" = "write" ] || [ "${DOMAIN}" = "edit" ]; then
        mkdir -p "${SESSION_DIR}" 2>/dev/null || true
        local count_file="${SESSION_DIR}/${SESSION_ID}.count"
        local write_count=0
        # Atomic increment via flock (with fallback if flock unavailable)
        if command -v flock &>/dev/null; then
            local lock_file="${SESSION_DIR}/${SESSION_ID}.lock"
            write_count=$(flock -x "${lock_file}" -c "
                count=0
                [ -f '${count_file}' ] && count=\$(cat '${count_file}' 2>/dev/null | tr -d '[:space:]') && count=\${count:-0}
                count=\$((count + 1))
                echo \$count > '${count_file}'
                echo \$count
            " 2>/dev/null || echo 1)
        else
            if [ -f "${count_file}" ]; then
                write_count=$(cat "${count_file}" 2>/dev/null | tr -d '[:space:]')
                write_count=${write_count:-0}
            fi
            write_count=$((write_count + 1))
            echo "${write_count}" > "${count_file}" 2>/dev/null || true
        fi
        if [ "${write_count}" -gt "${SESSION_WRITE_LIMIT}" ]; then
            emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "deny" "${DETAIL}" "session-write-limit" "critical" 90
            respond_deny "Session write limit exceeded (${write_count}/${SESSION_WRITE_LIMIT})"
            return
        fi
    fi

    # 6. Route based on action
    case "${MATCHED_ACTION}" in
        allow)
            # Audit if enabled
            if [ "${MATCHED_AUDIT}" = "true" ]; then
                emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "allow" "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_SEVERITY}" "${MATCHED_RISK_SCORE}"
            fi
            respond_allow
            ;;

        deny)
            emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "deny" "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_SEVERITY}" "${MATCHED_RISK_SCORE}"
            respond_deny "Blocked by rule ${MATCHED_RULE}: $(echo "${POLICY_RULES_JSON}" | jq -r ".[] | select(.id == \"${MATCHED_RULE}\") | .description" 2>/dev/null || echo "policy denied")"
            ;;

        ask)
            # Check availability mode
            local mode
            mode=$(get_availability_mode)

            case "${mode}" in
                away)
                    # M3: Writes and edits always queued in away mode
                    if [ "${DOMAIN}" = "write" ] || [ "${DOMAIN}" = "edit" ]; then
                        queue_for_review "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_RISK_SCORE}"
                        emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "away_queued" "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_SEVERITY}" "${MATCHED_RISK_SCORE}"
                        respond_deny "Away mode: write/edit actions require review."
                    elif [ "${MATCHED_RISK_SCORE}" -lt "${AWAY_THRESHOLD}" ]; then
                        # Low risk — auto-allow in away mode
                        emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "away_auto_allow" "${DETAIL}" "${MATCHED_RULE}" "info" "${MATCHED_RISK_SCORE}"
                        respond_allow
                    elif [ "${MATCHED_SEVERITY}" = "critical" ]; then
                        # Critical — halt
                        queue_for_review "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_RISK_SCORE}"
                        emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "away_halt" "${DETAIL}" "${MATCHED_RULE}" "critical" "${MATCHED_RISK_SCORE}"
                        respond_deny "Away mode: critical action halted. Queued for review."
                    else
                        # Medium risk — queue
                        queue_for_review "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_RISK_SCORE}"
                        emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "away_queued" "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_SEVERITY}" "${MATCHED_RISK_SCORE}"
                        respond_deny "Away mode: action queued for review."
                    fi
                    ;;

                active|review|*)
                    # Ask human via Telegram
                    local action_id
                    action_id=$(gen_id)

                    local ask_exit=0
                    telegram_ask "${action_id}" "${tool_name}" "${TOOL_DISPLAY}" "${MATCHED_RULE}" "${MATCHED_RISK_SCORE}" "${MATCHED_SEVERITY}" || ask_exit=$?
                    if [ "${ask_exit}" -eq 0 ]; then
                        emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "authorized" "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_SEVERITY}" "${MATCHED_RISK_SCORE}" "human:${TELEGRAM_CHAT_ID}"
                        respond_allow
                    else
                        local denied_by="${TELEGRAM_DENIED_BY:-unknown}"
                        local authorizer_tag="gate:${denied_by}"
                        [ "${ask_exit}" -eq 1 ] && authorizer_tag="human:${TELEGRAM_CHAT_ID}"
                        emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "denied" "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_SEVERITY}" "${MATCHED_RISK_SCORE}" "${authorizer_tag}"
                        respond_deny "[${denied_by}] Denied by ${denied_by} (rule ${MATCHED_RULE})"
                    fi
                    ;;
            esac
            ;;

        log)
            # Log only — allow but record
            emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "logged" "${DETAIL}" "${MATCHED_RULE}" "${MATCHED_SEVERITY}" "${MATCHED_RISK_SCORE}"
            respond_allow
            ;;

        *)
            # Unknown action — deny
            emit_event "${DOMAIN}" "${TOOL_DISPLAY}" "deny" "${DETAIL}" "${MATCHED_RULE}" "warn" 0
            respond_deny "Unknown policy action: ${MATCHED_ACTION}"
            ;;
    esac
}

# Run
main
