      "severity": "warn",
      "audit": true,
      "match": {
        "detail": {
          "path": {
            "contains": ".env"
          }
        }
      },
      "risk_score": {
        "irreversibility": 60,
        "consequence": 80,
        "blast_radius": 50
      }
    },
    {
      "id": "R036",
      "enabled": true,
      "description": "General file writes \u2014 allow",
      "domain": "write",
      "action": "allow",
      "severity": "info",
      "audit": true,
      "match": {
        "domain": "write"
      }
    },
    {
      "id": "R042",
      "enabled": true,
