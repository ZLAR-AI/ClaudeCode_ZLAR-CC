      "description": "Allow TodoWrite, TaskOutput, plan mode, user questions \u2014 low-risk state management",
      "domain": "state",
      "action": "allow",
      "severity": "info",
      "audit": true,
      "risk_score": {
        "irreversibility": 0,
        "consequence": 5,
        "blast_radius": 0
      }
    },
    {
      "id": "R090",
      "enabled": true,
      "description": "Web fetch \u2014 requires approval",
      "domain": "webfetch",
      "action": "ask",
      "severity": "warn",
      "audit": true,
      "match": {
